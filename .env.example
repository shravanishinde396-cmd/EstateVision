# ═══════════════════════════════════════
# Server Environment — .env
# ═══════════════════════════════════════

NODE_ENV=production
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/proppulse?retryWrites=true&w=majority

# JWT Secrets (min 64 chars, random)
JWT_ACCESS_SECRET=your-access-secret-minimum-64-characters-random-string-here-x1y2z3
JWT_REFRESH_SECRET=your-refresh-secret-minimum-64-characters-random-string-here-a1b2c3

# Client URL (CORS)
CLIENT_URL=https://proppulse.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Resend Email
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@proppulse.ai

# AI Microservice
AI_SERVICE_URL=https://proppulse-ai.railway.app

# ═══════════════════════════════════════
# Client Environment — client/.env
# ═══════════════════════════════════════

VITE_API_URL=https://api.proppulse.railway.app
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxx
VITE_MAPBOX_TOKEN=pk.eyxxxxx
VITE_SOCKET_URL=https://api.proppulse.railway.app
VITE_APP_NAME=PropPulse AI
